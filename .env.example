# =============================================================================
# Tinker — Environment Variables Template
# Copy this to .env and fill in your local values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://tinker:tinker@localhost:5432/tinker_dev
DATABASE_URL_TEST=postgresql://tinker:tinker@localhost:5432/tinker_test

# -----------------------------------------------------------------------------
# Cache / Queue
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-local-dev-only
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# GitHub App (for codebase integrations)
# -----------------------------------------------------------------------------
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# AI / LLM
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Observability (populated in non-local envs)
# -----------------------------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_BETA_FEATURES=true
